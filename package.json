{
  "name": "@k-l-lambda/lotus",
  "private": false,
  "version": "1.0.2",
  "description": "Lotus is a sheet music toolset, an enhancement of LilyPond.",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "browser": "lib.browser/lotus.umd.js",
  "scripts": {
    "start": "ts-node --project ./tsconfig.node.json ./main.ts",
    "dev": "ts-node-dev --project ./tsconfig.node.json ./main.ts",
    "dev:inspect": "ts-node-dev --project ./tsconfig.node.json --inspect -- ./main.ts",
    "serve": "vite",
    "build": "vite build",
    "build:lib": "(tsc --project ./tsconfig.node.json --skipLibCheck || true) && vite build --config vite.config.lib.ts && ts-node --project ./tsconfig.node.json ./tools/buildJisonParser.ts",
    "ts-run": "ts-node --project ./tsconfig.node.json",
    "ts-dev": "ts-node-dev --project ./tsconfig.node.json",
    "ts-dev:inspect": "ts-node-dev --project ./tsconfig.node.json --inspect --"
  },
  "author": "K.L.",
  "license": "ISC",
  "dependencies": {
    "@k-l-lambda/music-widgets": "^1.0.1"
  },
  "devDependencies": {
    "@k-l-lambda/web-editor": "^0.1.3",
    "@types/child-process-promise": "^2.2.1",
    "@types/events": "^3.0.0",
    "@types/express": "^4.17.3",
    "@types/node": "^14.0.13",
    "@types/yargs": "^15.0.5",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "@vitejs/plugin-vue": "^5.1.0",
    "@vue/compat": "^3.5.0",
    "@vue/compiler-sfc": "^3.5.0",
    "@vue/eslint-config-standard": "^8.0.1",
    "@vue/eslint-config-typescript": "^13.0.0",
    "@vueuse/core": "^14.0.0",
    "child-process-promise": "^2.2.1",
    "codejar": "^4.3.0",
    "comlink-loader": "^2.0.0",
    "crc-32": "^1.2.0",
    "diff": "^4.0.2",
    "dotenv": "^17.2.3",
    "dotenv-expand": "^12.0.3",
    "eslint": "^8.57.0",
    "eslint-plugin-vue": "^9.20.0",
    "express": "^4.17.1",
    "formidable": "^1.2.2",
    "http": "^0.0.0",
    "jison": "^0.4.18",
    "jszip": "^3.5.0",
    "liyad": "^0.4.1",
    "prismjs": "^1.20.0",
    "sass": "^1.77.6",
    "sass-loader": "^8.0.2",
    "serve-handler": "^6.1.3",
    "sha1": "^1.1.1",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
